{
  "name": "conduit-runtime",
  "version": "0.1.0",
  "description": "Subscription as a Runtime — turn any agent CLI (Claude, Codex, your own) into a normalized streaming runtime. Bring your own CLI by config, not code.",
  "type": "module",
  "private": true,
  "license": "MIT",
  "author": "akeildev",
  "homepage": "https://github.com/akeildev/conduit#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/akeildev/conduit.git"
  },
  "bugs": {
    "url": "https://github.com/akeildev/conduit/issues"
  },
  "engines": {
    "node": ">=23.6.0"
  },
  "bin": {
    "conduit": "./bin/conduit.ts",
    "conduit-serve": "./bin/conduit-serve.ts"
  },
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "conduit": "node bin/conduit.ts",
    "serve": "node bin/conduit-serve.ts",
    "detect": "node bin/conduit.ts detect",
    "test": "node --test test/*.test.ts",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "cli",
    "agent",
    "runtime",
    "claude",
    "codex",
    "bring-your-own-cli",
    "subscription-as-a-runtime",
    "streaming",
    "canonical-events"
  ],
  "devDependencies": {
    "typescript": "^5.7.0",
    "@types/node": "^22.0.0"
  }
}
